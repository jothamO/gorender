{
  "url": "http://localhost:3000/composition/my-video",
  "durationFrames": 300,
  "fps": 30,
  "width": 1080,
  "height": 1920,
  "seekParam": "frame",
  "readySignal": "window.__READY__ === true",
  "readyTimeout": "5s",
  "audio": [
    {
      "src": "./assets/background-music.mp3",
      "startFrame": 0,
      "volume": 0.6
    },
    {
      "src": "./assets/sfx-whoosh.mp3",
      "startFrame": 90,
      "volume": 1.0
    }
  ],
  "output": {
    "path": "./output/my-video.mp4",
    "format": "mp4",
    "crf": 20,
    "preset": "medium",
    "pixelFormat": "yuv420p"
  }
}
